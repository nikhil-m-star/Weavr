datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output   = "./generated-client"
}

model Student {
  id           String         @id // Clerk user ID (e.g. user_...)
  name         String
  email        String         @unique
  college      String?
  branch       String?
  gradYear     Int?
  cgpa         Float?
  githubUrl    String?
  linkedinUrl  String?
  bio          String?
  resumeUrl    String?
  verified     Boolean        @default(true) // Checked via Clerk sign-up
  createdAt    DateTime       @default(now())
  skills       StudentSkill[]
  applications Application[]
}

model Skill {
  id                String                  @id @default(uuid())
  name              String                  @unique // normalized lowercase
  students          StudentSkill[]
  requiredListings  ListingRequiredSkill[]
  preferredListings ListingPreferredSkill[]
}

model StudentSkill {
  studentId String
  skillId   String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  skill     Skill   @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([studentId, skillId])
}

model Company {
  id        String    @id // Clerk user ID
  name      String
  email     String    @unique
  createdAt DateTime  @default(now())
  listings  Listing[]
}

enum Location {
  REMOTE
  HYBRID
  ONSITE
}

enum ListingStatus {
  DRAFT
  ACTIVE
  CLOSED
}

model Listing {
  id                String                  @id @default(uuid())
  companyId         String
  company           Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  title             String
  description       String
  stipend           Float
  location          Location
  deadline          DateTime
  maxApplicants     Int
  currentApplicants Int                     @default(0)
  status            ListingStatus           @default(DRAFT)
  autoClosedAt      DateTime?
  closedReason      String?
  createdAt         DateTime                @default(now())
  targetBranch      String?
  targetGradYear    Int?
  requiredSkills    ListingRequiredSkill[]
  preferredSkills   ListingPreferredSkill[]
  applications      Application[]

  @@index([status])
  @@index([deadline])
}

model ListingRequiredSkill {
  listingId String
  skillId   String
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  skill     Skill   @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([listingId, skillId])
}

model ListingPreferredSkill {
  listingId String
  skillId   String
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  skill     Skill   @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([listingId, skillId])
}

enum ApplicationStatus {
  SUBMITTED
  UNDER_REVIEW
  SHORTLISTED
  REJECTED
  OFFER_EXTENDED
}

model Application {
  id        String            @id @default(uuid())
  studentId String
  listingId String
  status    ApplicationStatus @default(SUBMITTED)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  student   Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  listing   Listing           @relation(fields: [listingId], references: [id], onDelete: Cascade)
  nimScore       Float?
  nimFeedback    String?
  nimEvaluatedAt DateTime?

  @@unique([studentId, listingId])
  @@index([studentId])
  @@index([listingId])
}

enum RecipientType {
  STUDENT
  COMPANY
}

model Notification {
  id            String        @id @default(uuid())
  recipientType RecipientType
  recipientId   String
  message       String
  read          Boolean       @default(false)
  createdAt     DateTime      @default(now())

  @@index([recipientId, read])
}
